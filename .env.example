# Skopyr Environment Variables
# Copy this to .env.local and fill in your values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Skopyr

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-project-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Legacy database URL if you add your own direct Postgres tooling
DATABASE_URL=postgresql://user:password@localhost:5432/skopyr

# Paystack
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Authentication
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000
GOOGLE_ID=your-google-oauth-client-id
GOOGLE_SECRET=your-google-oauth-client-secret

# SMS (Termii)
TERMII_API_KEY=your-termii-key
TERMII_SENDER_ID=Skopyr

# File Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# NIN Verification API
NIN_VERIFICATION_API_KEY=your-key
NIN_VERIFICATION_API_URL=https://api.example.com/verify

# Redis (for sessions/caching)
REDIS_URL=redis://localhost:6379
